          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/QuestionResponse" } }
              },
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/QuestionResponse" } }
              },
              "text/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/QuestionResponse" } }
              }
            }
          }
        }
      }
    },
    "/api/Question/{id}": {
      "get": {
        "tags": ["Question"],
        "summary": "Получить вопрос по идентификатору",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Идентификатор вопроса",
            "required": true,
            "schema": { "type": "integer", "format": "int32" }
          }
        ],
        "responses": {
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "200": {
            "description": "OK",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/QuestionResponse" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/QuestionResponse" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/QuestionResponse" } }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          }
        }
      }
    },

    "/api/Attempts": {
      "post": {
        "tags": ["Attempts"],
        "summary": "Начать попытку",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CreateAttemptRequest" } },
            "text/json": { "schema": { "$ref": "#/components/schemas/CreateAttemptRequest" } },
            "application/*+json": { "schema": { "$ref": "#/components/schemas/CreateAttemptRequest" } }
          }
        },
        "responses": {
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "201": { "description": "Created" },
          "400": {
            "description": "Bad Request",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          }
        }
      },
      "put": {
        "tags": ["Attempts"],
        "summary": "Закончить попытку",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/UpdateAttemptRequest" } },
            "text/json": { "schema": { "$ref": "#/components/schemas/UpdateAttemptRequest" } },
            "application/*+json": { "schema": { "$ref": "#/components/schemas/UpdateAttemptRequest" } }
          }
        },
        "responses": {
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "201": { "description": "Created" },
          "204": { "description": "No Content" },
          "404": {
            "description": "Not Found",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          }
        }
      }
    },
    "/api/Attempts/{attemptId}/review": {
      "get": {
        "tags": ["Attempts"],
        "summary": "Получить разбор попытки",
        "parameters": [
          { "name": "attemptId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int32" } }
        ],
        "responses": {
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "200": {
            "description": "OK",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/AttemptReviewDto" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/AttemptReviewDto" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/AttemptReviewDto" } }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          }
        }
      }
    },

    "/api/StudentAnswers": {
      "post": {
        "tags": ["StudentAnswers"],
        "summary": "Дать ответ на вопрос",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CreateStudentAnswerRequest" } },
            "text/json": { "schema": { "$ref": "#/components/schemas/CreateStudentAnswerRequest" } },
            "application/*+json": { "schema": { "$ref": "#/components/schemas/CreateStudentAnswerRequest" } }
          }
        },
        "responses": {
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "200": { "description": "OK" },
          "400": {
            "description": "Bad Request",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          }
        }
      }
    },

    "/api/StudentTests/summary": {
      "get": {
        "tags": ["StudentTests"],
        "summary": "Получить сводку по попыткам всех доступных студенту тестов",
        "responses": {
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/StudentTestSummaryDto" } }
              },
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/StudentTestSummaryDto" } }
              },
              "text/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/StudentTestSummaryDto" } }
              }
            }
          }
        }
      }
    },

    "/api/TestResults/student": {
      "get": {
        "tags": ["TestResults"],
        "summary": "Получить результаты студента",
        "description": "После добавления авторизации получение id через параметры будет удалено",
        "responses": {
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "200": {
            "description": "OK",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/TestResultDto" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/TestResultDto" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/TestResultDto" } }
            }
          }
        }
      }
    },
    "/api/TestResults/test/{testId}": {
      "get": {
        "tags": ["TestResults"],
        "summary": "Получить результат теста для текущего студента",
        "description": "Позволяет получить детальную информацию о результатах прохождения конкретного теста",
        "parameters": [
          {
            "name": "testId",
            "in": "path",
            "description": "Идентификатор теста",
            "required": true,
            "schema": { "type": "integer", "format": "int32" }
          }
        ],
        "responses": {
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "200": {
            "description": "OK",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/TestResultDetailResponse" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/TestResultDetailResponse" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/TestResultDetailResponse" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthRequest": {
        "required": ["login", "password"],
        "type": "object",
        "properties": {
          "login": { "minLength": 1, "type": "string" },
          "password": { "minLength": 1, "type": "string" }
        },
        "additionalProperties": false
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "nullable": true },
          "title": { "type": "string", "nullable": true },
          "status": { "type": "integer", "format": "int32", "nullable": true },
          "detail": { "type": "string", "nullable": true },
          "instance": { "type": "string", "nullable": true }
        },
        "additionalProperties": {}
      },

      "CreateAttemptRequest": {
        "type": "object",
        "properties": {
          "testId": { "type": "integer", "description": "Идентификатор теста", "format": "int32" }
        },
        "additionalProperties": false,
        "description": "Модель начала попытки"
      },
      "UpdateAttemptRequest": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "Идентфикатор попытки", "format": "int32" }
        },
        "additionalProperties": false
      },

      "AttemptReviewDto": {
        "type": "object",
        "properties": {
          "attemptId": { "type": "integer", "format": "int32" },
          "testId": { "type": "integer", "format": "int32" },
          "score": { "type": "integer", "format": "int32" },
          "maxScore": { "type": "integer", "format": "int32" },
          "canShowReview": { "type": "boolean" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AttemptReviewItemDto" },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "AttemptReviewItemDto": {
        "type": "object",
        "properties": {
          "questionId": { "type": "integer", "format": "int32" },
          "answerType": { "type": "integer", "format": "int32" },
          "maxScore": { "type": "integer", "format": "int32" },
          "earned": { "type": "integer", "format": "int32" },
          "correctAnswerIds": {
            "type": "array",
            "items": { "type": "integer", "format": "int32" },
            "nullable": true
          },
          "selectedAnswerIds": {
            "type": "array",
            "items": { "type": "integer", "format": "int32" },
            "nullable": true
          }
        },
        "additionalProperties": false
      },

      "CreateStudentAnswerRequest": {
        "type": "object",
        "properties": {
          "attemptId": { "type": "integer", "description": "К какой попытке привязан выбор", "format": "int32" },
          "questionId": { "type": "integer", "description": "На какой вопрос дан ответ", "format": "int32" },
          "userSelectedOptions": {
            "type": "array",
            "items": { "type": "integer", "format": "int32" },
