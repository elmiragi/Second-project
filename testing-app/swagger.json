              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          }
        }
      }
    },

    "/api/Tests/available": {
      "get": {
        "tags": ["Tests"],
        "summary": "Получить список тестов (для студента)",
        "parameters": [
          { "name": "isPublic", "in": "query", "description": "Фильтр по публичности теста", "schema": { "type": "boolean" } },
          { "name": "searchTitle", "in": "query", "description": "Поиск по названию теста", "schema": { "type": "string" } },
          { "name": "sortBy", "in": "query", "description": "Поле для сортировки (\"Title\" или \"PublishedAt\")", "schema": { "type": "string" } },
          { "name": "sortDescending", "in": "query", "description": "Направление сортировки (true — по убыванию)", "schema": { "type": "boolean", "default": true } },
          { "name": "pageNumber", "in": "query", "description": "Номер страницы (начинается с 1)", "schema": { "type": "integer", "format": "int32", "default": 1 } },
          { "name": "pageSize", "in": "query", "description": "Размер страницы", "schema": { "type": "integer", "format": "int32", "default": 10 } }
        ],
        "responses": {
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TestResponse" } }
              },
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TestResponse" } }
              },
              "text/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TestResponse" } }
              }
            }
          }
        }
      }
    },
    "/api/Tests/{id}": {
      "get": {
        "tags": ["Tests"],
        "summary": "Получить тест по id (для студента)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Идентификатор теста",
            "required": true,
            "schema": { "type": "integer", "format": "int32" }
          }
        ],
        "responses": {
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          },
          "200": {
            "description": "OK",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/TestResponse" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/TestResponse" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/TestResponse" } }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "text/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } }
            }
          }
        }
      }
    },

    "/api/Question": {
      "get": {
        "tags": ["Question"],
        "summary": "Получить список вопросов",
        "parameters": [
          { "name": "testId", "in": "query", "schema": { "type": "integer", "format": "int32" } }
        ],
        "responses": {
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
              "application/json": { "schema": { "$ref": "#/components/schemas/ProblemDetails" } },
